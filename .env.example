# =====================================================
# Finora — 環境變數
# =====================================================
# 取得 Gemini / Gemma API key:
#   https://aistudio.google.com/apikey
# 沒填 → /api/chat 與 /api/analyze 自動 fallback 到 mock，demo 永遠可跑

GEMINI_API_KEY=

# 主模型（建議用 Gemma 4 31B dense）
# 其他可選：
#   gemma-4-26b-a4b-it   ← MoE 較快
#   gemma-3-27b-it       ← 上一代 dense
#   gemini-2.0-flash     ← 商業 Flash
GEMINI_MODEL=gemma-4-31b-it

# 主模型失敗時自動切換的備援
GEMINI_FALLBACK_MODEL=gemma-4-26b-a4b-it

# =====================================================
# 部署到 Vercel 時要填的 metadata（OG image / SEO 用）
# =====================================================
# 例：https://finora.vercel.app
NEXT_PUBLIC_SITE_URL=
